{
  "manifest_version": 3,
  "name": "NAI Send Eagle",
  "version": "1.0.0",
  "description": "NovelAI で生成した画像を自動的に Eagle へ送信します。",
  "icons": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
  },
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://novelai.net/image*",
    "http://localhost:41595/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://novelai.net/image*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "NAI Send Eagle"
  }
}
